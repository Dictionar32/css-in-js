{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "paths": {
      "@tailwind-styled/shared": ["./packages/shared/src/index.ts"],
      "@tailwind-styled/compiler": ["packages/domain/compiler/src/index.ts"],
      "@tailwind-styled/compiler/internal": ["packages/domain/compiler/src/internal.ts"],
      "@tailwind-styled/scanner": ["./packages/scanner/src/index.ts"],
      "@tailwind-styled/analyzer": ["packages/domain/analyzer/src/index.ts"],
      "@tailwind-styled/engine": ["packages/domain/engine/src/index.ts"],
      "@tailwind-styled/engine/internal": ["packages/domain/engine/src/internal.ts"],
      "@tailwind-styled/theme": ["./packages/theme/src/index.ts"],
      "@tailwind-styled/plugin": ["packages/domain/plugin/src/index.ts"],
      "@tailwind-styled/plugin-api": ["./packages/plugin-api/src/index.ts"],
      "@tailwind-styled/plugin/presets": ["packages/domain/plugin/src/presets.ts"],
      "@tailwind-styled/syntax": ["./packages/syntax/src/index.ts"],
      "@tailwind-styled/next": ["./packages/next/src/index.ts"],
      "@tailwind-styled/vite": ["./packages/vite/src/plugin.ts"],
      "@tailwind-styled/rspack": ["./packages/rspack/src/index.ts"],
      "@tailwind-styled/vue": ["./packages/vue/src/index.ts"],
      "@tailwind-styled/svelte": ["./packages/svelte/src/index.ts"],
      "@tailwind-styled/devtools": ["./packages/devtools/src/index.tsx"],
      "@tailwind-styled/animate": ["packages/domain/animate/src/index.ts"],
      "@tailwind-styled/runtime-css": ["./packages/runtime-css/src/index.ts"],
      "@tailwind-styled/preset": ["./packages/preset/src/index.ts"],
      "@tailwind-styled/theme/live-tokens": ["./packages/theme/src/liveTokens.ts"],
      "create-tailwind-styled": ["./packages/cli/src/index.ts"]
    }
  },
  "include": ["packages/*/src/**/*.ts", "packages/*/src/**/*.tsx"],
  "exclude": ["packages/*/src/**/*.test.ts", "packages/*/src/**/*.test.tsx", "packages/_experiments/**"]
}
