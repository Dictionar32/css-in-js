{
  "name": "create-tailwind-styled",
  "version": "5.0.4",
  "description": "CLI scaffolding tool — npx create-tailwind-styled",
  "license": "MIT",
  "type": "module",
  "main": "./dist/api.js",
  "types": "./dist/api.d.ts",
  "exports": {
    ".": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    },
    "./bin": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "create-tailwind-styled": "./dist/index.js",
    "tailwind-styled": "./dist/index.js",
    "tw": "./dist/index.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "check": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8",
    "typescript": "^6"
  }
}