{
  "name": "tailwind-styled-vscode",
  "version": "5.0.4",
  "license": "MIT",
  "displayName": "Tailwind Styled VS Code",
  "description": "VS Code extension for Tailwind Styled - trace, doctor, and why commands",
  "publisher": "tailwind-styled",
  "engines": {
    "node": ">=20",
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "IntelliSense"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:vue",
    "onLanguage:svelte"
  ],
  "main": "./dist/extension.js",
  "files": [
    "dist"
  ],
  "contributes": {
    "commands": [
      {
        "command": "tailwind-styled.trace",
        "title": "Tailwind Styled: Trace Class"
      },
      {
        "command": "tailwind-styled.why",
        "title": "Tailwind Styled: Why in Bundle"
      },
      {
        "command": "tailwind-styled.doctor",
        "title": "Tailwind Styled: Run Doctor"
      }
    ],
    "configuration": {
      "title": "Tailwind Styled",
      "properties": {
        "tailwindStyled.enableTraceHover": {
          "type": "boolean",
          "default": true,
          "description": "Enable hover trace for Tailwind classes"
        },
        "tailwindStyled.enableAutocomplete": {
          "type": "boolean",
          "default": true,
          "description": "Enable autocomplete for Tailwind classes"
        }
      }
    }
  },
  "scripts": {
    "build": "tsup src/extension.ts --format cjs --out-dir dist --external vscode",
    "dev": "tsup src/extension.ts --format cjs --out-dir dist --watch --external vscode",
    "check": "tsc --noEmit",
    "test": "tsx --test src/providers/classToken.test.ts src/providers/renameProviderError.test.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "pack:check": "node ../../scripts/check-pack-artifacts.mjs packages/vscode"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/vscode": "^1.75.0",
    "tsx": "^4.21.0",
    "tsup": "^8",
    "typescript": "^6"
  },
  "dependencies": {
    "@tailwind-styled/engine": "^5.0.4",
    "inversify": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  }
}