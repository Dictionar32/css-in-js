{
  "compilerOptions": {
    "rootDir": "src",
    "allowJs": true,
    "checkJs": false,
    "module": "Node16",
    "moduleResolution": "node16",
    "noEmit": true,
    "skipLibCheck": true,
    "target": "ES2020"
  },
  "include": ["src/**/*.js"],
  "exclude": ["dist-electron", "node_modules"]
}
