{
  "name": "@tailwind-styled/testing",
  "version": "5.0.4",
  "description": "Testing matchers and helpers for tailwind-styled",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist --clean",
    "dev": "tsup src/index.ts --format esm --dts --out-dir dist --watch",
    "clean": "rm -rf dist",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^6"
  }
}