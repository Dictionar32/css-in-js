{
  "name": "@tailwind-styled/preset",
  "version": "5.0.4",
  "description": "Default Tailwind preset for tailwind-styled-v5 \u2014 v5 with Tailwind v4 CSS-first support",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./default": {
      "types": "./dist/defaultPreset.d.ts",
      "import": "./dist/defaultPreset.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/defaultPreset.ts --format esm --dts --out-dir dist --clean",
    "dev": "tsup src/index.ts src/defaultPreset.ts --format esm --dts --out-dir dist --watch",
    "check": "tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "pack:check": "node ../../scripts/check-pack-artifacts.mjs packages/preset"
  },
  "dependencies": {
    "inversify": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  }
}
