{
  "name": "@tailwind-styled/plugin-registry",
  "version": "5.0.4",
  "description": "Plugin discovery and install helper for the tailwind-styled v5 ecosystem",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tw-plugin": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "registry.json"],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --out-dir dist --clean",
    "dev": "tsup src/index.ts src/cli.ts --format esm --dts --out-dir dist --watch",
    "clean": "rm -rf dist",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^6"
  }
}