{
  "name": "@tailwind-styled/rspack",
  "version": "5.0.4",
  "description": "Rspack adapter for tailwind-styled-v4 — loader + plugin",
  "author": "Dictionar32",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./loader": {
      "types": "./dist/loader.d.ts",
      "import": "./dist/loader.js"
    }
  },
  "files": ["dist", "README.md"],
  "peerDependencies": {
    "@rspack/core": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@rspack/core": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/loader.ts --format esm --dts --out-dir dist --clean",
    "dev": "tsup src/index.ts src/loader.ts --format esm --dts --out-dir dist --watch",
    "clean": "rm -rf dist",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^6"
  }
}