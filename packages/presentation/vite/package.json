{
  "name": "@tailwind-styled/vite",
  "version": "5.0.4",
  "description": "PRO Engine: styled-components + Tailwind CSS v4, zero-runtime compile, variant system, responsive props, plugin ecosystem",
  "author": "Dictionar32",
  "license": "MIT",
  "keywords": [
    "tailwind",
    "tailwindcss",
    "styled-components",
    "css-in-js",
    "variants",
    "vite",
    "zero-runtime",
    "typescript"
  ],
  "homepage": "https://github.com/Dictionar32/tailwind-styled-v4",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dictionar32/tailwind-styled-v4.git"
  },
  "bugs": {
    "url": "https://github.com/Dictionar32/tailwind-styled-v4/issues"
  },
  "readme": "README.md",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    }
  },
  "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/plugin.ts --format esm --dts --out-dir dist --clean",
    "dev": "tsup src/plugin.ts --format esm --dts --out-dir dist --watch",
    "clean": "rm -rf dist",
    "check": "tsc --noEmit"
  },
  "peerDependencies": {
    "vite": ">=6.2.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8",
    "typescript": "^6"
  }
}